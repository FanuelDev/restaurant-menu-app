    "cy:run:admin": "cypress run --spec 'cypress/e2e/admin/**/*.cy.ts'",
    "cy:run:super-admin": "cypress run --spec 'cypress/e2e/super-admin/**/*.cy.ts'"
  },
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.0",
