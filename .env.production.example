# ================================================================
# PRODUCTION — Copier en .env.production et remplir toutes les valeurs
# Ne jamais versionner .env.production dans git (.gitignore l'exclut)
# ================================================================

# ── Application ────────────────────────────────────────────────────────────────
TZ=UTC
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production

# URL publique du site (sans slash final)
APP_URL=https://saemenus.com

# Générer avec : cd backend && node ace generate:key
APP_KEY=

# ── Base de données MySQL ──────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_DATABASE=restaurant_menu
DB_USER=restaurant_user

# Mots de passe forts — utiliser un générateur (ex: openssl rand -base64 32)
DB_PASSWORD=<mot_de_passe_mysql_fort>
DB_ROOT_PASSWORD=<mot_de_passe_root_mysql_fort>

# ── MinIO (stockage S3-compatible) ────────────────────────────────────────────
# Ne pas utiliser les valeurs par défaut minioadmin/minioadmin en production
MINIO_ROOT_USER=NinioFanuelDev2.0
MINIO_ROOT_PASSWORD=NinioDev2.0@26726

# URL publique des images (proxy nginx /media/ → MinIO interne)
# Format : https://votredomaine.com/media  (sans slash final)
S3_CDN_URL=https://saemenus.com/media

# ── CORS ────────────────────────────────────────────────────────────────────────
# URL exacte du frontend (avec sous-domaine si multi-tenant)
# Pour multi-tenant : https://votredomaine.com suffit (le middleware cors accepte les sous-domaines)
CORS_ORIGIN=https://saemenus.com

# ── CinetPay ────────────────────────────────────────────────────────────────────
# Tableau de bord CinetPay → Mon compte → Intégration API
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# Ces URLs doivent être accessibles depuis les serveurs CinetPay
CINETPAY_NOTIFY_URL=https://saemenus.com/webhooks/cinetpay
CINETPAY_RETURN_URL=https://saemenus.com/admin/subscription
