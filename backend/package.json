{
  "name": "restaurant-menu-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node --import=tsx/esm ace.js serve --watch",
    "test": "node --import=tsx/esm ace.js test",
    "migration:run": "node --import=tsx/esm ace.js migration:run",
    "migration:rollback": "node --import=tsx/esm ace.js migration:rollback",
    "migration:status": "node --import=tsx/esm ace.js migration:status",
    "migration:fresh": "node --import=tsx/esm ace.js migration:fresh",
    "db:seed": "node --import=tsx/esm ace.js db:seed"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js"
  },
  "dependencies": {
    "@adonisjs/auth": "^9.2.3",
    "@adonisjs/core": "^6.12.0",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/drive": "^3.4.1",
    "@aws-sdk/client-s3": "^3.577.0",
    "@aws-sdk/s3-request-presigner": "^3.577.0",
    "@adonisjs/lucid": "^21.3.0",
    "luxon": "^3.4.4",
    "mysql2": "^3.9.7",
    "reflect-metadata": "^0.2.2",
    "@vinejs/vine": "^2.1.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.7.0",
    "@adonisjs/tsconfig": "^1.4.0",
    "@japa/api-client": "^2.0.3",
    "@japa/runner": "^3.1.4",
    "@swc/core": "^1.7.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.0.0",
    "hot-hook": "^0.3.1",
    "pino-pretty": "^11.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "~5.6.3"
  },
  "hotHook": {
    "boundaries": [
      "./start/routes.js",
      "./start/kernel.js"
    ]
  }
}
