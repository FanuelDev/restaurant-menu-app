# ==================================================
# APPLICATION
# ==================================================
TZ=UTC
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development

# ==================================================
# BASE DE DONNÉES (MySQL)
# ==================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=restaurant_user
DB_PASSWORD=restaurant_pass
DB_DATABASE=restaurant_menu


# ==================================================
# AUTHENTIFICATION
# ==================================================
# Durée de vie des tokens d'accès (ex: 30days, 7days, 1hour)
ACCESS_TOKEN_EXPIRY=30days

# ==================================================
# UPLOAD FICHIERS
# ==================================================
# "local" ou "s3" pour MinIO/S3
DRIVE_DISK=local

# Chemin local des uploads (relatif à la racine du projet)
LOCAL_UPLOADS_PATH=./public/uploads

# URL publique servant les fichiers uploadés localement
LOCAL_UPLOADS_URL=http://localhost:3333/uploads

# ==================================================
# MINIO / S3 (si DRIVE_DISK=s3)
# ==================================================
S3_KEY=minioadmin
S3_SECRET=minioadmin
S3_BUCKET=restaurant-menu
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
# Force path-style pour MinIO (obligatoire)
S3_FORCE_PATH_STYLE=true
# URL publique des images en prod — proxy nginx vers MinIO (laisser vide en dev)
# Exemple : https://votredomaine.com/media
S3_CDN_URL=

# ==================================================
# CORS
# ==================================================
# Liste des origines autorisées, séparées par des virgules
CORS_ORIGIN=http://localhost:4200

# ==================================================
# LIMITES D'UPLOAD
# ==================================================
MAX_IMAGE_SIZE_MB=5

# ==================================================
# CINETPAY (paiement en ligne)
# https://cinetpay.com — Tableau de bord → API
# ==================================================
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id
# URL de retour après paiement (page de confirmation côté frontend)
CINETPAY_RETURN_URL=http://localhost:4200/admin/subscription?payment=success
# URL de notification webhook (doit être accessible par CinetPay)
CINETPAY_NOTIFY_URL=http://your-domain.com/webhooks/cinetpay

# ==================================================
# APP URL (utilisé pour construire les liens)
# ==================================================
APP_URL=http://localhost:3333

